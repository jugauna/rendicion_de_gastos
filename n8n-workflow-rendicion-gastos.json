      "name": "IF Aprobada",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        3200,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Code — Batch email').first().json;\nconst ids = prev.id_rendiciones || [];\nconst decision = $json.query?.decision || $json.body?.decision || $json.decision || '';\nconst aprobada = decision === 'aprobar';\nconst estado = aprobada ? 'Aprobada' : 'Rechazada';\nreturn ids.map(id => ({ json: { ID_Rendicion: id, Estado: estado, Fecha_Resolucion: new Date().toISOString() } }));"
      },
