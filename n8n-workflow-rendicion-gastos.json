        }
      },
      "id": "sheets-update-estado",
      "name": "Sheets — Update por ID_Rendicion",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        3680,
        300
      ],
      "notesInFlow": true,
      "notes": "En la UI: operación Update, modo por fila, columna a buscar = ID_Rendicion, valor = expresión $json.ID_Rendicion (según versión n8n)."
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all();\nif (!rows.length) return [];\nconst estado = rows[0].json.Estado;\nif (estado === 'Aprobada') {\n  return [{ json: { _notificar_contable: true } }];\n}\nreturn [];"
      },
